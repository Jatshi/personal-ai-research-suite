# Root template. Copy this file to .env locally. Never commit real keys.
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Module-specific config selectors.
PERSONAL_ACADEMIC_RAG_CONFIG=config.production.yaml
PERSONAL_AI_CONFIG=config.production.yaml
LOCAL_MCP_CONFIG=config.local_project.example.yaml

# Optional API protection for personal-ai-workspace FastAPI.
PERSONAL_AI_API_TOKEN=change-me
